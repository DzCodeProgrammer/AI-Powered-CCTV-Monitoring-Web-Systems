# App
APP_NAME=Smart CCTV Face Recognition
APP_ENV=development
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key

# Server
HOST=127.0.0.1
PORT=8000

# Database
DB_DRIVER=mysql

# MySQL credentials — run: python scripts/generate_secrets.py
MYSQL_ROOT_PASSWORD=change-this-mysql-root-password
DB_HOST=localhost
DB_PORT=3306
DB_USER=cctv_user
DB_PASSWORD=change-this-cctv-db-password
DB_NAME=smart_cctv

# Camera
CAMERA_SOURCE=0
# RTSP_URL=rtsp://admin:password@192.168.1.100:554/stream1

# Face Recognition
FACE_MODEL=Facenet
RECOGNITION_THRESHOLD=0.55
DETECTION_INTERVAL=1.0
ATTENDANCE_INTERVAL=300

# Paths
DATASET_DIR=datasets
SCREENSHOT_DIR=screenshots
LOG_DIR=logs

# Admin (seeded on first startup if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
SESSION_MAX_AGE=86400
